{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false,
    "types": ["node"],
    "paths": {
      "@tachy/core": ["./packages/core/src/index.ts"],
      "@tachy/source-freshdesk": ["./packages/sources/freshdesk/src/index.ts"]
    }
  }
}
