# Postgres
DATABASE_URL=postgres://tachy:tachy@localhost:5433/tachy
PORT=8787

# docker-compose only; keep consistent with DATABASE_URL
POSTGRES_USER=tachy
POSTGRES_PASSWORD=tachy
POSTGRES_DB=tachy

# Credential vault master key (openssl rand -base64 32).
# Unset = vault disabled; source tokens and agent keys can't be stored in-app.
# TACHY_SECRET_KEY=

# Session cookie signing secret (32+ chars).
# Unset = everyone is logged out on every restart.
# TACHY_SESSION_SECRET=

# Bearer token for REST automation (scripts, CI). Optional.
# TACHY_API_TOKEN=

# OIDC SSO (Microsoft Entra or any provider). Optional.
# OIDC_ISSUER=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=
