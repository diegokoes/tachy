# Postgres
DATABASE_URL=postgres://tachy:tachy@localhost:5432/tachy
PORT=8787

# Only read by docker-compose.yml, to configure the bundled postgres
# container. Keep these consistent with DATABASE_URL above. Not used if
# you're running Postgres yourself.
POSTGRES_USER=tachy
POSTGRES_PASSWORD=tachy
POSTGRES_DB=tachy

# Where the local embedding model is cached. The Docker image already bakes
# one in at build time; only set this if you want a different/persisted path.
# FASTEMBED_CACHE=.fastembed-cache

# Who knowledge entries / feedback are attributed to (created_by). Upserted into
# the users table on first use. Leave unset to record entries anonymously.
TACHY_USER_EMAIL=you@example.com

# ── Auth ──────────────────────────────────────────────────────────────────
# Shared bearer token for the REST API / automation. Also unlocks the web UI
# in "token" mode. If neither this nor OIDC is set, the API binds to 127.0.0.1
# only (authMode=open, laptop dev). The MCP server (stdio) ignores this.
TACHY_API_TOKEN=replace_with_a_long_random_secret

# authMode is auto-derived (sso if OIDC below is set, else token if the bearer
# is set, else open). Override explicitly if needed: sso | token | open.
# TACHY_AUTH_MODE=sso

# Microsoft Entra (or any OIDC provider) single sign-on for interactive users.
# Set all three to enable SSO. Register OIDC_REDIRECT_URI in the app registration.
#   Entra issuer: https://login.microsoftonline.com/<TENANT_ID>/v2.0
# OIDC_ISSUER=https://login.microsoftonline.com/<TENANT_ID>/v2.0
# OIDC_CLIENT_ID=<application-client-id>
# OIDC_CLIENT_SECRET=<client-secret>
# OIDC_REDIRECT_URI=https://tachy.example.com/auth/callback
# OIDC_SCOPES=openid profile email offline_access
# Session-cookie signing secret (>=32 chars), required when OIDC is set:
# TACHY_SESSION_SECRET=replace_with_a_long_random_secret_min_32_chars

# ── Agent (server-side reasoning) ───────────────────────────────────────────
# The web Chat drives the Claude Agent SDK. It authenticates with an API key,
# or — if unset — the Claude Code login present on the server (mount ~/.claude).
# A shared multi-user subscription may conflict with Anthropic's usage terms;
# prefer an API key for a company deployment.
# ANTHROPIC_API_KEY=sk-ant-...
# Model for the agent (default claude-opus-4-8). Drop to sonnet/haiku for cost:
# TACHY_AGENT_MODEL=claude-opus-4-8
# Where uploaded docs are staged for the agent to ingest (default: OS tmp dir):
# TACHY_UPLOAD_DIR=/app/uploads

# Freshdesk — token is resolved per source slug:
#   FRESHDESK_TOKEN_<SLUG>  (slug uppercased, non-alphanumerics -> _)
# Falls back to FRESHDESK_TOKEN if the per-slug var is absent.
# Use your NON-ADMIN token. The ":X" password part is added automatically.
FRESHDESK_TOKEN_MY_FRESHDESK=replace_with_your_token

# GitHub — same per-slug pattern: GITHUB_TOKEN_<SLUG>, falling back to
# GITHUB_TOKEN. A classic/fine-grained PAT with read access to the repos
# (and issues:write only if you later enable posting comments).
GITHUB_TOKEN=replace_with_your_pat
