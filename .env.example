# Postgres
DATABASE_URL=postgres://tachy:tachy@localhost:5432/tachy
PORT=8787

# Only read by docker-compose.yml, to configure the bundled postgres
# container. Keep these consistent with DATABASE_URL above. Not used if
# you're running Postgres yourself.
POSTGRES_USER=tachy
POSTGRES_PASSWORD=tachy
POSTGRES_DB=tachy

# Where the local embedding model is cached. The Docker image already bakes
# one in at build time; only set this if you want a different/persisted path.
# FASTEMBED_CACHE=.fastembed-cache

# Who knowledge entries / feedback are attributed to (created_by). Upserted into
# the users table on first use. Leave unset to record entries anonymously.
TACHY_USER_EMAIL=you@example.com

# Shared bearer token for the REST API. If unset, the API binds to 127.0.0.1
# only and accepts no remote requests. The MCP server (stdio) ignores this.
TACHY_API_TOKEN=replace_with_a_long_random_secret

# Freshdesk — token is resolved per source slug:
#   FRESHDESK_TOKEN_<SLUG>  (slug uppercased, non-alphanumerics -> _)
# Falls back to FRESHDESK_TOKEN if the per-slug var is absent.
# Use your NON-ADMIN token. The ":X" password part is added automatically.
FRESHDESK_TOKEN_OSAPIENS_FRESHDESK=replace_with_your_token

# GitHub — same per-slug pattern: GITHUB_TOKEN_<SLUG>, falling back to
# GITHUB_TOKEN. A classic/fine-grained PAT with read access to the repos
# (and issues:write only if you later enable posting comments).
GITHUB_TOKEN=replace_with_your_pat
