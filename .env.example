# ── Bootstrap (required to boot) ────────────────────────────────────────────
DATABASE_URL=postgres://tachy:tachy@localhost:5432/tachy
PORT=8787

# docker-compose only; keep consistent with DATABASE_URL
POSTGRES_USER=tachy
POSTGRES_PASSWORD=tachy
POSTGRES_DB=tachy

# Embedding model cache path (Docker image bakes one in already)
# FASTEMBED_CACHE=.fastembed-cache

# ── Secrets (env only — never stored in the database) ───────────────────────
# Shared bearer for REST API automation (scripts, CI). Interactive users sign
# in via the setup wizard's password login or SSO instead.
TACHY_API_TOKEN=replace_with_a_long_random_secret

# Signs login session cookies (password + SSO). Unset = ephemeral secret,
# sessions reset on every restart.
TACHY_SESSION_SECRET=replace_with_a_long_random_secret_min_32_chars

# Microsoft Entra (or any OIDC) SSO — set all three to enable; coexists with
# password login.
# OIDC_ISSUER=https://login.microsoftonline.com/<TENANT_ID>/v2.0
# OIDC_CLIENT_ID=<application-client-id>
# OIDC_CLIENT_SECRET=<client-secret>
# OIDC_REDIRECT_URI=https://tachy.example.com/auth/callback
# OIDC_SCOPES=openid profile email offline_access

# Agent API key, or falls back to the server's Claude Code login if unset
# ANTHROPIC_API_KEY=sk-ant-...

# Freshdesk — FRESHDESK_TOKEN_<SLUG> (uppercased, non-alphanumerics -> _), falls
# back to FRESHDESK_TOKEN. Use a non-admin token.
FRESHDESK_TOKEN_MY_FRESHDESK=replace_with_your_token

# GitHub — same pattern: GITHUB_TOKEN_<SLUG>, falls back to GITHUB_TOKEN
GITHUB_TOKEN=replace_with_your_pat

# ── Fallback defaults (now managed in the setup wizard / Admin › System) ────
# These runtime settings live in the DATABASE. The env vars below only act as
# fallback defaults until a DB value is set — new installs shouldn't need them.
# TACHY_REDACT=true                      # -> setting: redaction_global
# TACHY_AGENT_MODEL=claude-sonnet-5      # -> setting: agent_model
# TACHY_AGENT_EFFORT=medium              # -> setting: agent_effort (low|medium|high|xhigh|max)
# TACHY_ALLOWED_MODELS=                  # -> setting: allowed_models (comma-separated)

# ── Misc (optional) ──────────────────────────────────────────────────────────
# Attribution for the STANDALONE MCP server (Claude Desktop). The web agent
# attributes from the logged-in user instead.
# TACHY_USER_EMAIL=you@example.com
# TACHY_AUTH_MODE=sso                    # sso | token | open — auto-derived if omitted
# TACHY_UPLOAD_DIR=/app/uploads          # default: OS tmp dir
