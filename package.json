{
  "name": "tachy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted knowledge engine for engineering work items. Pluggable sources (Freshdesk, GitHub, ...), Claude-Code-driven ingest/consult loop.",
  "license": "AGPL-3.0-or-later",
  "workspaces": [
    "packages/core",
    "packages/sources/freshdesk",
    "packages/sources/github",
    "packages/mcp",
    "packages/agent",
    "packages/api",
    "packages/cli",
    "packages/web"
  ],
  "scripts": {
    "mcp": "tsx packages/mcp/src/index.ts",
    "api": "tsx packages/api/src/index.ts",
    "sync": "tsx packages/cli/src/index.ts",
    "web:dev": "npm run dev --workspace @tachy/web",
    "web:build": "npm run build --workspace @tachy/web",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=24.18.0",
    "npm": ">=10"
  },
  "overrides": {
    "tar": "7.5.19",
    "fastembed": {
      "tar": "6.2.1",
      "onnxruntime-node": {
        "tar": "7.5.19"
      }
    }
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.3",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
